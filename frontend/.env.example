# Anti-spoof / quét mặt (captureFaceFromVideo.js)
# Full khung + PNG (mặc định) — tốt hơn cho PAD khi có ảnh trên điện thoại.
# VITE_FACE_ANTISPOOF_FULL_FRAME=1
# VITE_FACE_ANTISPOOF_IMAGE_FORMAT=png
#
# Nhẹ băng thông / chỉ crop oval gửi AI (PAD kém hơn):
# VITE_FACE_ANTISPOOF_FULL_FRAME=0
# VITE_FACE_ANTISPOOF_IMAGE_FORMAT=jpeg
