PORT=5000
NODE_ENV=development

# PostgreSQL (chọn 1 cách)
# Cách 1: 1 biến duy nhất
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
# PGSSL=false
#
# Cách 2: tách biến
PGHOST=localhost
PGPORT=5432
PGDATABASE=Deepfake
PGUSER=postgres
PGPASSWORD=12345678
PGSSL=false

# JWT for auth (đổi trong production)
JWT_SECRET=deepcheck-secret-change-in-production
