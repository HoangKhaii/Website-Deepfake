PORT=5000
NODE_ENV=development

# Dev + Vite proxy /api: bật 1 để đọc X-Forwarded-For từ proxy (IP thật). Tắt nếu API mở thẳng ra internet không có proxy tin cậy.
TRUST_PROXY=1

# PostgreSQL (chon 1 cach)
# Cach 1: 1 bien duy nhất
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
# PGSSL=false
#
# Cach 2: tach bien (Supabase)
PGHOST=aws-1-ap-northeast-1.pooler.supabase.com
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres.ckxusxtbzliwwapmvqbj
PGPASSWORD=o0xWudkbsRuMlLnL
PGSSL=true

