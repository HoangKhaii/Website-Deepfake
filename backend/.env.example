# =============================================================================
# ĐĂNG KÝ / ĐĂNG NHẬP MẶT — Silent-Face-Anti-Spoofing (không dùng deepfake_ai)
# Mặc định: antilogin-gateway (5003) → forward tới FastAPI 8010. Chạy gateway: cd antilogin-gateway && npm start
# Silent-Face FastAPI: python -m api.main (configs/api.yaml host 0.0.0.0, port 8010)
# VPN / máy xa: dùng IP Radmin của máy chạy gateway
# Gọi thẳng FastAPI (bỏ gateway): ANTI_SPOOF_PREDICT_URL=http://IP:8010/predict
# Alias: ANTILOGIN_GATEWAY_PREDICT_URL (= cùng URL với ANTI_SPOOF_PREDICT_URL)
# =============================================================================
ANTI_SPOOF_PREDICT_URL=http://26.54.212.200:5003/api/predict
# Ví dụ VPN: ANTI_SPOOF_PREDICT_URL=http://26.91.146.177:5003/api/predict
# Trên máy chạy Silent-Face (Python): thử ANTI_SPOOF_BBOX_MODE=largest nếu replay điện thoại vẫn bị REAL (mặc định maxconf).
# ANTI_SPOOF_MIN_SCORE=0.3
#
# PAD tĩnh bị “đánh lừa” REAL: bật kiểm tra độ thay đổi giữa các frame (avg-hash). 0 = tắt.
# Trung bình số bit khác nhau giữa hai frame liên tiếp phải >= ngưỡng (256 bit tối đa). Thử 1.5–3.
# FACE_LIVENESS_MIN_INTERFRAME_HASH_BITS_MEAN=2

# =============================================================================
# DEEPFAKE — ai-gateway (5001): chỉ upload ảnh/video + (tùy) so khớp mặt compare-faces
# =============================================================================
AI_GATEWAY_DETECT_URL=http://26.54.212.200:5001/api/detect
# Độ khớp tối thiểu AI compare (0–1), mặc định 0.7 = 70%
# FACE_COMPARE_MIN_SCORE=0.7
AI_GATEWAY_COMPARE_URL=http://26.54.212.200:5001/api/compare-faces
# Hoặc thẳng compare_face (ví dụ port 5004): http://26.54.212.200:5004/api/compare-faces
# Số ảnh mặt lưu khi đăng ký (JSON trong face_image), mặc định 10
# FACE_STORED_REFERENCE_COUNT=10

# Face login: hash = so avg-hash (mặc định, không cần API compare). gateway = chỉ API so sánh.
# FACE_COMPARE_MODE=hash
# Ngưỡng khớp hash (0.5–1), mặc định 0.80 — tăng nếu hay nhận nhầm người khác; giảm nhẹ nếu hay trượt cùng người.
# FACE_VERIFY_HASH_MIN_SCORE=0.80

# --- Đăng nhập / đăng ký mặt: đa số frame Silent-Face (23 frame mặc định) ---
# >= floor(N/2)+1 frame fake → từ chối; >= ngưỡng đó frame real → đạt, rồi mới so khớp mặt.
# Chỉ thống kê blur (không chặn). Laplacian variance tối thiểu coi là “mờ”, mặc định 100
# FACE_LIVENESS_BLUR_VAR_MIN=100

# =============================================================================
# UPLOAD_AI — upload-ai-gateway (cổng 5002), field "file" → forward FastAPI máy chủ
# Clone về: chạy "npm start" trong upload-ai-gateway/ rồi giữ mặc định dưới đây.
# Máy chủ TUANANH chỉ chạy FastAPI upload_ai, không chạy gateway: dùng dòng comment.
# =============================================================================
UPLOAD_AI_PREDICT_URL=http://26.54.212.200:5002/api/predict
# UPLOAD_AI_PREDICT_URL=http://26.54.212.200:8001/api/v1/predict

# Database, JWT, ... (các biến .env hiện có của bạn)

# =============================================================================
# IP client (email “thiết bị lạ”) — bật khi Node nằm sau nginx/Caddy/reverse proxy
# TRUST_PROXY=1  → req.ip / X-Forwarded-For đúng máy khách; tắt nếu API mở trực tiếp ra internet
# =============================================================================
# TRUST_PROXY=1

# Sau khi đổi mật khẩu (forgot-password): xóa hết thiết bị tin cậy → lần sau phải OTP lại (bảo mật hơn)
# Mặc định false để tránh coi máy bạn là “lạ” sau mỗi lần đổi mk (thiết bị tin cậy lưu DB)
# REVOKE_TRUSTED_ON_PASSWORD_RESET=true

# =============================================================================
# reCAPTCHA v2 ("I'm not a robot") — đăng ký khuôn mặt POST /auth/register-face
# Admin: https://www.google.com/recaptcha/admin — Site key → frontend VITE_RECAPTCHA_SITE_KEY
# =============================================================================
# RECAPTCHA_SECRET_KEY=
